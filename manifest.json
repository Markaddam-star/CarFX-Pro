{
  "manifest_version": 3,
  "name": "CarFX Pro",
  "version": "1.0.1",
  "description": "Cinematic car animation engine",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/engine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
