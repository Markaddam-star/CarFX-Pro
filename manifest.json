{
  "manifest_version": 3,
  "name": "CarFX Pro",
  "version": "1.0.0",
  "description": "Cinematic car animation engine",

  "permissions": ["storage"],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
